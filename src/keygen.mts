// Experiment with generating a key pair, uploading the public key to the server,
// and authenticating with the private key.
import {
  createJsApiFactories,
  createPasswordCredentials,
  generateBase64KeyPair,
  initCorePlusManager,
  keyWithSentinel,
  loginClientWithKeyPair,
  uploadPublicKey,
  type KeyPairCredentials,
} from '@deephaven-enterprise/jsapi-nodejs'
import { loginPrompt } from './utils/loginPrompt.mjs'

const { serverUrl, username, password } = await loginPrompt()

const jsApiFactories = createJsApiFactories()

const corePlusManager = await initCorePlusManager({
  serverUrl,
  credentials: createPasswordCredentials(username, password),
  jsapiFactories: jsApiFactories,
})
const { dhe, dheClient } = corePlusManager

const { publicKey, privateKey, type } = await generateBase64KeyPair()

console.log()
console.log(
  [
    `user ${username}`,
    `operateas ${username}`,
    `public ${keyWithSentinel(type, publicKey)}`,
    `private ${keyWithSentinel(type, privateKey)}`,
  ].join('\n'),
)
console.log()

// NOTE: this currently fails due to what seems to be a bug with node's fetch
// for http2 servers. We get around this in gRPC using the custom transport, and
// in VS Code extension by enabling "Http: Electron Fetch" setting.
await uploadPublicKey({
  dheClient,
  userName: username,
  comment: `Generated by DH repl ${new Date().toISOString()}`,
  publicKey,
  type,
})

const keyPairCredentials: KeyPairCredentials = {
  type: 'keyPair',
  username,
  keyPair: {
    type: 'ec',
    publicKey,
    privateKey,
  },
}

await loginClientWithKeyPair(
  await jsApiFactories.createEnterpriseClient(dhe, serverUrl),
  keyPairCredentials,
)

process.exit(0)
